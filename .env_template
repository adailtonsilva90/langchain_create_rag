# Google Gemini API Key
GOOGLE_API_KEY=<your_google_api_key_here>

# PostgreSQL Configuration (pgvector)
POSTGRES_USER=<db_user_here>
POSTGRES_PASSWORD=<db_password_here>
POSTGRES_DB=<db_name_here>
POSTGRES_HOST=<db_host_here>
POSTGRES_PORT=<db_port_here>

# Gemini models (Multimodal Extraction & QA)
GEMINI_ANALYSIS_MODEL=models/gemini-2.5-flash
GEMINI_QUERY_MODEL=models/gemini-2.5-flash
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# pgAdmin default credentials (for the interface)
PGADMIN_DEFAULT_EMAIL=<admin_email_here>
PGADMIN_DEFAULT_PASSWORD=<admin_password_here>
