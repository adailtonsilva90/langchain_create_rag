# --- Google Gemini Configuration ---
# Your Google AI Studio API Key
# Obtain at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Gemini model for semantic analysis (e.g., models/gemini-flash-latest)
GEMINI_ANALYSIS_MODEL=your_analysis_model_id

# Gemini model for question answering (e.g., models/gemini-pro-latest)
GEMINI_QUERY_MODEL=your_query_model_id

# --- PostgreSQL (pgvector) Configuration ---
# Database connection credentials and settings
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_database_name
POSTGRES_HOST=database_host_address
POSTGRES_PORT=database_port

# --- Ollama Configuration ---
# Base URL for the Ollama server
# Use http://localhost:11434 if Ollama is running on your host machine
OLLAMA_BASE_URL=ollama_service_url

# --- pgAdmin Configuration ---
# Initial setup credentials for the pgAdmin interface
PGADMIN_DEFAULT_EMAIL=admin_account_email
PGADMIN_DEFAULT_PASSWORD=admin_account_password
